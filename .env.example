# =====================================================================
# Zentral landing — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored (see .gitignore); never commit real secrets.
# In production (Vercel / your host), set the same keys in the dashboard.
# =====================================================================

# ---- Resend (waitlist form: storage + transactional email) ----------
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Audience (contact list) ID where waitlist signups land.
# Create one at https://resend.com/audiences then paste its ID here.
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Verified sender. Must be a domain you've verified in Resend.
# Format: "Display Name <inbox@your-domain.com>"
RESEND_FROM=Zentral <noreply@zentral.indrox.com>

# Where the internal admin notification email goes when someone signs up.
WAITLIST_NOTIFY_EMAIL=admin@indrox.com
